# Obtain this from your J-Quants dashboard. Do not commit the resulting .env file.
JQUANTS_API_KEY=

# Required only when LINE notifications are enabled in config/notification.yaml.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_RECIPIENT_ID=

# Optional GitHub Fine-grained personal access token for chart publishing.
# Restrict it to the Pinknokumo repository. Do not commit the real value.
GITHUB_CHARTS_TOKEN=
